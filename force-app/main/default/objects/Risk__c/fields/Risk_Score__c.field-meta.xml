<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Risk_Score__c</fullName>
    <formula>CASE(TEXT(Likelihood__c), &quot;Low&quot;, 1, &quot;Medium&quot;, 2, &quot;High&quot;, 3, &quot;Critical&quot;, 4, 0) * CASE(TEXT(Impact__c), &quot;Low&quot;, 1, &quot;Medium&quot;, 2, &quot;High&quot;, 3, &quot;Critical&quot;, 4, 0)</formula>
    <label>Risk Score</label>
    <precision>18</precision>
    <scale>0</scale>
    <type>Number</type>
</CustomField>
